---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
]
---

<nav class="nav-bar">
  <ul class="nav-list">
    {navItems.map(item => (
      <li class="nav-item">
        <a class="nav-link" href={item.href}>{item.label}</a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .nav-bar {
    display: flex;
    justify-content: center;
    padding: 1rem;
    background: #111;
  }

  .nav-list {
    display: flex;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .nav-link {
    color: #fff;
    text-decoration: none;
    font-weight: 600;
  }

  .nav-link:hover {
    color: #0af;
  }
</style>
